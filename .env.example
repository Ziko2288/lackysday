# Copy this file to .env and fill in real values before deploying.

PORT=3000

# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Invite code new users must enter at registration to become an admin.
# Keep this private — anyone who has it can grant themselves admin access.
ADMIN_CODE=

# UTC hour (0-23) at which ticket sales close and the daily draw runs.
DRAW_HOUR_UTC=20

TICKET_COST=10
START_BALANCE=500
JACKPOT_BASE=1000
JACKPOT_CONTRIB=5
